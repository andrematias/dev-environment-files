font-family = JetBrainsMono Nerd Font
font-feature = +liga 
font-size = 16
# theme = light:Apple System Colors Light,dark:Gruvbox Dark Hard
theme = light:Apple System Colors Light,dark:Catppuccin Mocha
window-padding-x = 0
window-padding-y = 0
window-padding-balance = true
cursor-style = block
macos-titlebar-style = tabs

shell-integration = zsh
shell-integration-features = no-cursor
mouse-hide-while-typing = true
scrollback-limit = 1000000
# window-save-state = always
keybind = super+r=reload_config


# For tmux like keybinding
keybind = ctrl+b>q=quit
keybind = ctrl+b>t=new_tab
keybind = ctrl+b>o=toggle_tab_overview
keybind = ctrl+b>s=new_window
keybind = ctrl+b>p=previous_tab
keybind = ctrl+b>n=next_tab
keybind = ctrl+b>1=goto_tab:1
keybind = ctrl+b>2=goto_tab:2
keybind = ctrl+b>3=goto_tab:3
keybind = ctrl+b>4=goto_tab:4
keybind = ctrl+b>5=goto_tab:5
keybind = ctrl+b>6=goto_tab:6
keybind = ctrl+b>7=goto_tab:7
keybind = ctrl+b>8=goto_tab:8
keybind = ctrl+b>9=goto_tab:9
keybind = ctrl+b>6=goto_tab:6


# to create split and navigate it
keybind = ctrl+b>f=toggle_split_zoom
keybind = ctrl+b>shift+\=new_split:right
keybind = ctrl+b>minus=new_split:down
keybind = ctrl+b>z=toggle_split_zoom
# keybind = ctrj+b>h=new_split:left
# keybind = ctrl+b>j=new_split:down
# keybind = ctrl+b>k=new_split:up
# keybind = ctrl+b>l=new_split:right

keybind = ctrl+b>h=goto_split:left
keybind = ctrl+b>j=goto_split:bottom
keybind = ctrl+b>k=goto_split:top
keybind = ctrl+b>l=goto_split:right
keybind = ctrl+b>x=close_surface
keybind = ctrl+b>equal=equalize_splits

# for resizing split
keybind = ctrl+shift+h=resize_split:left,10
keybind = ctrl+shift+l=resize_split:right,10
keybind = ctrl+shift+k=resize_split:up,10
keybind = ctrl+shift+j=resize_split:down,10
keybind = ctrl+b>r=reload_config

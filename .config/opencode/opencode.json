{
  "$schema": "https://opencode.ai/config.json",
  "formatter": false,
  "mcp": {
    "bitbucket": {
      "command": ["npx", "-y", "@aashari/mcp-server-atlassian-bitbucket"],
      "environment": {
        "ATLASSIAN_API_TOKEN": "xxx",
        "ATLASSIAN_USER_EMAIL": "andre.matias@mutant.com.br",
        "BITBUCKET_DEFAULT_WORKSPACE": "unearsa"
      },
      "type": "local"
    },
    "intellij": {
      "command": [
        "/opt/intellij-idea-ultimate-edition/jbr/bin/java",
        "-classpath",
        "/opt/intellij-idea-ultimate-edition/plugins/mcpserver/lib/mcpserver-frontend.jar:/opt/intellij-idea-ultimate-edition/lib/util-8.jar:/opt/intellij-idea-ultimate-edition/lib/module-intellij.libraries.ktor.client.cio.jar:/opt/intellij-idea-ultimate-edition/lib/module-intellij.libraries.ktor.client.jar:/opt/intellij-idea-ultimate-edition/lib/module-intellij.libraries.ktor.network.tls.jar:/opt/intellij-idea-ultimate-edition/lib/module-intellij.libraries.ktor.io.jar:/opt/intellij-idea-ultimate-edition/lib/module-intellij.libraries.ktor.utils.jar:/opt/intellij-idea-ultimate-edition/lib/module-intellij.libraries.kotlinx.io.jar:/opt/intellij-idea-ultimate-edition/lib/module-intellij.libraries.kotlinx.serialization.core.jar:/opt/intellij-idea-ultimate-edition/lib/module-intellij.libraries.kotlinx.serialization.json.jar",
        "com.intellij.mcpserver.stdio.McpStdioRunnerKt"
      ],
      "environment": {
        "IJ_MCP_SERVER_PORT": "64343"
      },
      "type": "local"
    },
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "pycharm": {
      "command": [
        "/opt/pycharm/jbr/bin/java",
        "-classpath",
        "/opt/pycharm/plugins/mcpserver/lib/mcpserver-frontend.jar:/opt/pycharm/lib/util-8.jar:/opt/pycharm/lib/module-intellij.libraries.ktor.client.cio.jar:/opt/pycharm/lib/module-intellij.libraries.ktor.client.jar:/opt/pycharm/lib/module-intellij.libraries.ktor.network.tls.jar:/opt/pycharm/lib/module-intellij.libraries.ktor.io.jar:/opt/pycharm/lib/module-intellij.libraries.ktor.utils.jar:/opt/pycharm/lib/module-intellij.libraries.kotlinx.io.jar:/opt/pycharm/lib/module-intellij.libraries.kotlinx.serialization.core.jar:/opt/pycharm/lib/module-intellij.libraries.kotlinx.serialization.json.jar",
        "com.intellij.mcpserver.stdio.McpStdioRunnerKt"
      ],
      "environment": {
        "IJ_MCP_SERVER_PORT": "64342"
      },
      "type": "local"
    }
  },
  "provider": {
    "ollama": {
      "models": {
        "gemma4:26b": {
          "name": "gemma4:26b"
        },
        "qwen2.5-coder:7b": {
          "name": "Qwen 2.5 Coder"
        },
        "qwen3.5:35b-a3b-coding-nvfp4": {
          "name": "qwen3.5:35b MLX"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      }
    }
  }
}
